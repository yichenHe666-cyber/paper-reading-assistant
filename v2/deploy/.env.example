# 核动力科研牛马 v2 — 环境变量示例。
#
# 用法：cd deploy && cp .env.example .env，按需修改后 docker compose up -d。
# 必须在 deploy/ 目录下执行 docker compose，否则 compose 会误加载上层目录的 .env。
# 所有变量均可被环境变量覆盖，.env 仅提供默认值。

# ===== LLM 配置 =====
# provider：ollama / deepseek / openai-compat
LLM_PROVIDER=ollama
# API 基址：
#   - 容器部署用 http://host.docker.internal:11434/v1（compose 已配 extra_hosts）
#   - 本机裸跑用 http://127.0.0.1:11434/v1
#   - deepseek 用 https://api.deepseek.com/v1
LLM_API_BASE=http://host.docker.internal:11434/v1
# API key：ollama 留空；deepseek/其他 OpenAI 兼容服务必填
LLM_API_KEY=
# 模型名：ollama 如 qwen2.5:7b；deepseek 如 deepseek-chat
LLM_MODEL=qwen2.5:7b
# 可选：LLM 调用超时（秒）、单次最大 token、温度、每日预算（USD）
LLM_TIMEOUT=90
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.3
DAILY_LLM_BUDGET_USD=3.0

# ===== Embedding 配置（Rust core 用）=====
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
# 同 LLM_API_BASE 规则：容器用 host.docker.internal，本机用 127.0.0.1
EMBEDDING_API_BASE=http://host.docker.internal:11434
EMBEDDING_API_KEY=
EMBEDDING_TIMEOUT_SECS=30

# ===== 论文数据源配置 =====
# company 源追踪 9 家 AI 公司（deepseek/openai/anthropic/google/deepmind/xai/kimi/qwen/meta）的 GitHub org
# 匿名访问限 60/hour，有 token 提升到 5000/hour
GITHUB_TOKEN=
# arXiv 单分类最大拉取数（默认 100，避免单源耗时过长）
ARXIV_MAX_RESULTS=100
# OpenAlex polite pool：留邮箱可获更高限速（不强制）
OPENALEX_MAILTO=
# 种子论文清单路径（容器内 /data/seed_papers.json，本机裸跑用相对/绝对路径）
# 一般不需要改
# SEED_PAPERS_PATH=

# ===== 部署端口（docker-compose 用）=====
# frontend 对外端口（浏览器访问）
FRONTEND_PORT=8080
# backend 仅本机暴露（经 nginx 反代），一般不改
BACKEND_PORT=8000

# ===== 记忆系统参数（Rust core 用）=====
# 时效性半衰期（天）：控制记忆衰减速度
RECENCY_HALF_LIFE_DAYS=30
# 超龄记忆不再升级为长期（天）
MAX_AGE_DAYS=365
