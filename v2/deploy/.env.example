# 核动力科研牛马 v2 — 环境变量示例。
#
# 用法：cp deploy/.env.example deploy/.env，按需修改后 docker compose up -d。
# 所有变量均可被环境变量覆盖，.env 仅提供默认值。

# ===== LLM 配置 =====
# provider：ollama / deepseek / openai-compat
LLM_PROVIDER=ollama
# API 基址：ollama 默认本地 11434；deepseek 用 https://api.deepseek.com/v1
LLM_API_BASE=http://127.0.0.1:11434/v1
# API key：ollama 留空；deepseek/其他 OpenAI 兼容服务必填
LLM_API_KEY=
# 模型名：ollama 如 qwen2.5:7b；deepseek 如 deepseek-chat
LLM_MODEL=qwen2.5:7b

# ===== Embedding 配置（Rust core 用）=====
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_API_BASE=http://127.0.0.1:11434
EMBEDDING_API_KEY=

# ===== GitHub 论文同步 =====
# 匿名访问限 60/hour，有 token 提升到 5000/hour
GITHUB_TOKEN=
DEFAULT_GITHUB_REPO=papers-we-love/papers-we-love

# ===== 部署端口（docker-compose 用）=====
# frontend 对外端口（浏览器访问）
FRONTEND_PORT=8080
# backend 仅本机暴露（经 nginx 反代），一般不改
BACKEND_PORT=8000

# ===== 记忆系统参数（spec §5.3）=====
# 时效性半衰期（天）：控制记忆衰减速度
RECENCY_HALF_LIFE_DAYS=30
# 超龄记忆不再升级为长期（天）
MAX_AGE_DAYS=365
