# ========================================
# 数据库
# ========================================
DATABASE_PATH=data/reading_assistant.db

# ========================================
# Obsidian Vault 路径
# ========================================
OBSIDIAN_VAULT_PATH=C:\\Users\\Public\\Documents

# ========================================
# GitHub 数据源
# ========================================
DEFAULT_GITHUB_REPO=papers-we-love/papers-we-love

# ========================================
# LLM 配置 (OpenAI 兼容接口)
# ========================================
LLM_PROVIDER=DeepSeek
LLM_API_BASE=https://api.deepseek.com/v1
LLM_API_KEY=sk-your-key-here
LLM_MODEL=deepseek-v4-pro
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.3
LLM_TIMEOUT=120

# ========================================
# LLM 成本管控
# ========================================
DAILY_LLM_BUDGET_USD=3.0
REQUIRE_APPROVAL_ABOVE_COST=0.10

# ========================================
# API 安全
# ========================================
API_KEY=

# ========================================
# 服务端口
# ========================================
API_PORT=8000
STREAMLIT_PORT=8501
