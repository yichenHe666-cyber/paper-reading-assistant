# 思考强度控制 (DeepSeek 模型支持)
# disabled = 关闭思考模式(响应最快)
# high = 标准思考深度(默认)
# max = 最大思考深度(适合复杂推理)
LLM_REASONING_EFFORT=max

# ========================================
# 数据库
# ========================================
DATABASE_PATH=data/reading_assistant.db

# ========================================
# Obsidian Vault 路径
# ========================================
OBSIDIAN_VAULT_PATH=C:\\Users\\Public\\Documents

# ========================================
# GitHub 数据源
# ========================================
DEFAULT_GITHUB_REPO=papers-we-love/papers-we-love

# ========================================
# LLM 配置 (OpenAI 兼容接口)
# ========================================
LLM_PROVIDER=DeepSeek
LLM_API_BASE=https://api.deepseek.com/v1
LLM_API_KEY=sk-your-key-here
LLM_MODEL=deepseek-v4-pro
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.3
LLM_TIMEOUT=120

# ========================================
# LLM 成本管控
# ========================================
DAILY_LLM_BUDGET_USD=3.0
REQUIRE_APPROVAL_ABOVE_COST=0.10

# ========================================
# 搜索引擎配置
# ========================================
# 默认搜索引擎，支持逗号分隔多引擎：duckduckgo,tavily,arxiv,google,bing,serper,exa
RETRIEVER=duckduckgo
# 搜索引擎降级链（默认引擎失败时按此顺序尝试）
SEARCH_FALLBACK_CHAIN=duckduckgo,tavily,arxiv

# Tavily 搜索 API Key (https://tavily.com)
TAVILY_API_KEY=
# Google Custom Search API Key + CX (https://developers.google.com/custom-search)
GOOGLE_API_KEY=
GOOGLE_CX=
# Bing 搜索 API Key (https://www.microsoft.com/en-us/bing/apis/bing-web-search-api)
BING_API_KEY=
# Serper Google SERP 代理 Key (https://serper.dev)
SERPER_API_KEY=
# Exa 语义搜索 API Key (https://exa.ai)
EXA_API_KEY=
# Perplexity AI 搜索 API Key (https://perplexity.ai)
PERPLEXITY_API_KEY=

# 搜索重试与限流
SEARCH_MAX_RETRIES=3
SEARCH_RETRY_BASE_DELAY=2.0
SEARCH_RATE_LIMIT_INTERVAL=3.0

# ========================================
# API 安全
# ========================================
API_KEY=

# ========================================
# 服务端口
# ========================================
API_PORT=8000
STREAMLIT_PORT=8501

# ========================================
# 记忆系统增强配置
# ========================================
# 嵌入提供者: auto(自动检测) / ollama(本地) / openai(云端) / disabled(关闭)
EMBEDDING_PROVIDER=auto
# Ollama 嵌入服务地址
OLLAMA_BASE_URL=http://localhost:11434
# 嵌入模型名称
EMBEDDING_MODEL=nomic-embed-text
# 记忆检索权重（语义,关键词,实体）
MEMORY_SEARCH_WEIGHTS=0.4,0.3,0.3
